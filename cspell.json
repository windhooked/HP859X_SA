{
  "version": "0.2",
  "language": "en,en-GB",
  "description": "HP 859X emulator — whitelisted technical / domain vocabulary so spell-check stops flagging real identifiers + accepts British English alongside American.",

  "ignoreRegExpList": [
    "0x[0-9a-fA-FxX]+",
    "[Dd][0-7]\\b",
    "[Aa][0-7]\\b"
  ],

  "ignorePaths": [
    "**/*.bin",
    "**/*.hex",
    "**/*.HEX",
    "**/*.asm",
    "**/*.rar",
    "**/*.jed",
    "**/*.JED",
    "**/*.pld",
    "**/*.PLD",
    "hp8593a_eeproms/**",
    "docs/rom.asm",
    "screens/*.png",
    "third_party/**",
    "tmp/**",
    "**/testdata/**"
  ],

